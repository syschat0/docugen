APP_NAME="LLM Document Agent"
APP_ENV="development"
DATABASE_PATH="data/app.sqlite3"
LLM_ENABLED="true"
LLM_BASE_URL="http://localhost:8088/v1"
LLM_API_KEY="local"
LLM_MODEL="qwen/qwen3.6-35b-a3b"
LLM_TIMEOUT_SECONDS="180"
LLM_MERGE_ENABLED="false"
SENTENCE_QUALITY_REPAIR_ENABLED="true"
SENTENCE_QUALITY_REPAIR_LIMIT="3"
REQUIRE_OUTLINE_APPROVAL="false"
SEARCH_ENABLED="true"
SEARCH_BACKEND="auto"
# Engine priority (comma-separated), tried in order with fallback on block/error.
# Engines: daum, bing, google, google_pse. e.g. "google_pse,bing,daum".
SEARCH_ENGINE="daum"
# Google Programmable Search Engine (for SEARCH_ENGINE="google_pse"): API key
# with the Custom Search API enabled, and the engine ID (cx) from
# programmablesearchengine.google.com. Free tier is ~100 queries/day; on
# quota errors the next engine in SEARCH_ENGINE takes over.
GOOGLE_PSE_API_KEY=""
GOOGLE_PSE_CX=""
SEARCH_MAX_RESULTS="5"
SEARCH_TIMEOUT_SECONDS="15"
# Browser search backend controls. Run headed (SEARCH_HEADLESS="false") plus
# stealth (SEARCH_STEALTH="true", needs playwright-stealth) to pass bot checks;
# headed needs a display and opens a browser window per search.
SEARCH_HEADLESS="true"
SEARCH_STEALTH="false"
# Browser context locale; drives result language (e.g. "en-US" for English).
SEARCH_LOCALE="ko-KR"
# Search-query language: "native" (request language), "english", or "both"
# (a mix, so results span both languages). Pairs well with a bilingual engine
# priority (e.g. SEARCH_ENGINE="bing,daum") and SEARCH_LOCALE.
SEARCH_QUERY_LANGUAGE="native"
CHAPTER_SEARCH_RESULTS="2"
# Cleaned page body kept per source so the passage selector can pick relevant
# sentences instead of a truncated lead.
SOURCE_FULL_TEXT_CHARS="5000"
# LLM source-quality judge: one call per eligible page gates, compresses, and
# scores it. Off automatically when LLM_ENABLED is false.
SOURCE_EVAL_ENABLED="true"
# Max real LLM evaluation calls per pipeline stage (cache hits are free).
SOURCE_EVAL_LIMIT="8"
# Total character budget for the source block in a section-writing prompt.
SOURCE_CONTEXT_BUDGET_CHARS="3000"
# Listwise section-fit judge: one LLM call per section scores every candidate
# source 0-3 for relevance to that section. Off automatically when LLM_ENABLED
# is false.
SECTION_EVAL_ENABLED="true"
# Max real listwise LLM calls per section-writing run (cache hits are free).
SECTION_EVAL_LIMIT="20"
SECTION_SEARCH_ENABLED="false"
SECTION_SEARCH_TOPUP_LIMIT="10"
DIAGRAMS_ENABLED="false"
CITATION_STYLE="numeric"
