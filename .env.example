APP_NAME="LLM Document Agent"
APP_ENV="development"
DATABASE_PATH="data/app.sqlite3"
LLM_ENABLED="true"
LLM_BASE_URL="http://localhost:8088/v1"
LLM_API_KEY="local"
LLM_MODEL="qwen/qwen3.6-35b-a3b"
LLM_TIMEOUT_SECONDS="180"
LLM_MERGE_ENABLED="false"
REQUIRE_OUTLINE_APPROVAL="false"
SEARCH_ENABLED="true"
SEARCH_BACKEND="auto"
# Engine priority (comma-separated), tried in order with fallback on block/error.
# Engines: daum, bing, google. e.g. "google,bing,daum".
SEARCH_ENGINE="daum"
SEARCH_MAX_RESULTS="5"
SEARCH_TIMEOUT_SECONDS="15"
# Browser search backend controls. Run headed (SEARCH_HEADLESS="false") plus
# stealth (SEARCH_STEALTH="true", needs playwright-stealth) to pass bot checks;
# headed needs a display and opens a browser window per search.
SEARCH_HEADLESS="true"
SEARCH_STEALTH="false"
# Browser context locale; drives result language (e.g. "en-US" for English).
SEARCH_LOCALE="ko-KR"
# Search-query language: "native" (request language), "english", or "both"
# (a mix, so results span both languages). Pairs well with a bilingual engine
# priority (e.g. SEARCH_ENGINE="bing,daum") and SEARCH_LOCALE.
SEARCH_QUERY_LANGUAGE="native"
CHAPTER_SEARCH_RESULTS="2"
SECTION_SEARCH_ENABLED="false"
SECTION_SEARCH_TOPUP_LIMIT="10"
DIAGRAMS_ENABLED="false"
CITATION_STYLE="numeric"
